FROM node:20-alpine as build

WORKDIR /app

# 安装依赖
COPY frontend/package*.json ./
RUN npm install

# 复制代码
COPY frontend/ .

# 构建
RUN npm run build

# 使用 nginx 提供服务
FROM nginx:alpine

# 复制构建结果
COPY --from=build /app/dist /usr/share/nginx/html

# 复制 nginx 配置
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
