# ============================================================
# 剧作大师 (ScriptMaster) - Git 忽略规则
# ============================================================

# ------------------------------------------------------------
# 🔴 敏感配置文件（包含 API Key 等隐私数据，绝对不能提交）
# ------------------------------------------------------------
# 环境变量文件（包含 API Key、密钥等敏感信息）
.env
.env.local
.env.*.local
*.env

# 但保留模板文件，供其他开发者参考
!.env.example
!**/.env.example

# 密钥文件
*.pem
*.key
*.crt
secrets.json
credentials.json

# ------------------------------------------------------------
# 🐍 Python 相关
# ------------------------------------------------------------
# 虚拟环境（体积大，且包含本地路径）
venv/
.venv/
env/
.env/
ENV/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.pyo

# 分发/打包
dist/
build/
*.egg-info/
*.egg
.eggs/

# 测试覆盖率
.coverage
htmlcov/
.pytest_cache/
.tox/

# mypy 类型检查
.mypy_cache/

# ------------------------------------------------------------
# 📦 Node.js / 前端相关
# ------------------------------------------------------------
# 依赖目录（体积巨大）
node_modules/

# 构建产物
dist/
build/
.vite/

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------
# 💻 IDE 和编辑器
# ------------------------------------------------------------
# VSCode
.vscode/
*.code-workspace

# JetBrains IDE (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~

# ------------------------------------------------------------
# 🖥️ 操作系统生成文件
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ------------------------------------------------------------
# 📝 日志文件
# ------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------
# 🗂️ 临时文件和缓存
# ------------------------------------------------------------
# 通用临时文件
*.tmp
*.temp
*.bak
*.cache

# 备份文件
*.backup
*.old

# ------------------------------------------------------------
# 🧪 测试和覆盖率报告
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# 📦 打包文件
# ------------------------------------------------------------
*.zip
*.tar.gz
*.rar
*.7z

# ------------------------------------------------------------
# 🔧 项目特定忽略规则
# ------------------------------------------------------------
# SQLite 数据库（包含用户配置和 API Key）
backend/data/
*.db
*.db-journal
*.sqlite
*.sqlite3

# Claude Code 工作目录（可能包含临时对话数据）
.claude/

# Playwright MCP 缓存
.playwright-mcp/

# 文档目录（内部文档不提交）
docs/

# 导出文件目录（用户生成的文档）
backend/exports/

# 临时测试文件
test-*.py
test-*.ts
*.test.js

# ------------------------------------------------------------
# 📄 文档临时文件
# ------------------------------------------------------------
~$*.docx
~$*.xlsx
~$*.pptx
