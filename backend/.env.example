# 剧作大师后端环境配置
# 复制此文件为 .env 并修改配置

# ============================================
# 应用配置
# ============================================
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS 配置（前端访问地址，多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================
# LLM 大模型配置（必填）
# ============================================

# 模型提供商（必填）
# 可选值：tongyi, wenxin, zhipu, doubao, kimi, gemini, deepseek, openai, claude, custom
LLM_PROVIDER=tongyi

# API 密钥（必填）
# 请替换为你的实际 API 密钥
LLM_API_KEY=your_api_key_here

# API 基础地址（自定义模型时需要）
# 例如：http://localhost:11434/v1 (Ollama)
LLM_API_BASE=

# 模型名称（可选，留空使用默认）
# 通义千问: qwen-max, qwen-plus, qwen-turbo
# 文心一言: ernie-bot-4, ernie-bot
# OpenAI: gpt-4, gpt-3.5-turbo
# Claude: claude-3-opus, claude-3-sonnet
LLM_MODEL=qwen-max

# 温度参数（0.0-1.0，越高越创造性）
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=4000

# ============================================
# 各平台 API 密钥获取地址
# ============================================
# 通义千问: https://dashscope.aliyun.com/
# 文心一言: https://console.bce.baidu.com/ai/
# 智谱 AI: https://open.bigmodel.cn/
# 豆包: https://console.volcengine.com/
# Kimi: https://platform.moonshot.cn/
# Gemini: https://makersuite.google.com/
# DeepSeek: https://platform.deepseek.com/
# OpenAI: https://platform.openai.com/
# Claude: https://console.anthropic.com/

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=backend.log
